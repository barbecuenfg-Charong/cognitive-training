{
  "name": "cognitive-training-hub",
  "version": "1.0.0",
  "description": "Cognitive Training Hub - A collection of brain training games",
  "main": "main.js",
  "scripts": {
    "web": "node server.js",
    "start": "electron .",
    "package": "electron-packager . cognitive-training --platform=win32 --arch=x64 --out=dist --overwrite",
    "check:syntax": "node scripts/check-syntax.js",
    "check:sensitive-paths": "node scripts/check-sensitive-paths.js",
    "check:fontawesome-loading": "node scripts/audit-fontawesome-loading.js",
    "check:feedback-signals": "node scripts/smoke-feedback-signals.js",
    "check:picky-player": "node scripts/picky-player-audit.js --check",
    "check": "npm run check:syntax && npm run check:sensitive-paths && npm run check:fontawesome-loading && npm run smoke:pages && npm run smoke:flows && npm run check:feedback-signals && npm run check:picky-player",
    "audit:picky-player": "node scripts/picky-player-audit.js --write",
    "smoke:pages": "node scripts/smoke-pages.js",
    "smoke:flows": "node scripts/flow-smoke.js"
  },
  "keywords": [
    "cognitive",
    "training",
    "electron"
  ],
  "author": "Cognitive Training Developer",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-packager": "^17.1.2"
  }
}
